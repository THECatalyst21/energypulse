# Database (PostgreSQL - Update for your database)
# For local development, use a local PostgreSQL or Neon/SUPABASE free tier
DATABASE_URL="postgresql://user:password@localhost:5432/energypulse?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/energypulse?schema=public"

# Admin Credentials (CHANGE THESE FOR PRODUCTION!)
ADMIN_EMAIL="admin@energypulse.com"
ADMIN_PASSWORD="admin123"

# NextAuth Secret (Generate a random string for production)
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="energypulse-super-secret-key-change-in-production-2025"

# NextAuth URL (Update for your domain)
NEXTAUTH_URL="http://localhost:3000"
